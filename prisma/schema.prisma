generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id              String   @id @default(cuid())
  cedula          String   @unique
  fechaNacimiento String?
  apellidos       String
  nombres         String
  pais            String   @default("VENEZUELA")
  estado          String   @default("")
  municipio       String   @default("")
  seccion         String   @default("")
  plan            String   @default("vigente")
  rawData         String   @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  certifications Certification[]
  boletaNotas     BoletaNota[]
  boletaExtras    BoletaExtra[]

  @@index([cedula])
  @@index([apellidos])
  @@index([nombres])
}

model Certification {
  id           String   @id @default(cuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tipo         String   @default("certificacion")
  numero       String   @default("")
  fechaEmision DateTime @default(now())
  datos        String   @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([studentId])
  @@index([tipo])
}

// Notas por lapso para boletines (BOLETAS)
model BoletaNota {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  anioEscolar String   // Ej: "2021-2022"
  grado       String   // Ej: "2" (2do año)
  seccion     String   // Ej: "A"
  materia     String   // Ej: "Castellano"
  lapso1      String?  // Nota numérica o IN/PE
  lapso2      String?
  lapso3      String?
  revision    String?  // Nota de revisión (columna Rev. del boletín)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([studentId, anioEscolar, grado, seccion, materia])
  @@index([studentId])
  @@index([anioEscolar, grado, seccion])
}

// Datos extra por alumno en boletas (GRUPO, OBS)
model BoletaExtra {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  anioEscolar String
  grado       String
  seccion     String
  grupo1      String?   // Exoneración grupo lapso 1 (ej: "EXONERADO")
  grupo2      String?
  grupo3      String?
  grupo4      String?
  observacion String?  // Observaciones generales (col OBS del Excel)
  obsBoletin  String?  // Observaciones del boletín (col OBSBOLETIN del Excel)
  // Materia Pendiente (cols BD-BM del Excel)
  materiaPendiente1 String?  // Nombre materia pendiente 1 (col MP1)
  materiaPendiente2 String?  // Nombre materia pendiente 2 (col MP2)
  mp1m1 String?  // Materia Pendiente 1, Momento 1 (col 1M primer set)
  mp1m2 String?  // Materia Pendiente 1, Momento 2 (col 2M primer set)
  mp1m3 String?  // Materia Pendiente 1, Momento 3 (col 3M primer set)
  mp1m4 String?  // Materia Pendiente 1, Momento 4 (col 4M primer set)
  mp2m1 String?  // Materia Pendiente 2, Momento 1 (col 1M segundo set)
  mp2m2 String?  // Materia Pendiente 2, Momento 2 (col 2M segundo set)
  mp2m3 String?  // Materia Pendiente 2, Momento 3 (col 3M segundo set)
  mp2m4 String?  // Materia Pendiente 2, Momento 4 (col 4M segundo set)
  // Pendiente Lapso (cols BO-BS del Excel)
  pl1 String?   // Pendiente Lapso 1
  pl2 String?   // Pendiente Lapso 2
  pl3 String?   // Pendiente Lapso 3
  pl4 String?   // Pendiente Lapso 4
  pl5 String?   // Pendiente Lapso 5
  // Notas por asignatura definitive (cols BU-CA del Excel: CA, ILE, MA, EF, AP, CN, GHC)
  scoreCA  String?  // Castellano
  scoreILE String?  // Inglés
  scoreMA  String?  // Matemática
  scoreEF  String?  // Ed. Física
  scoreAP  String?  // Arte y Patrimonio
  scoreCN  String?  // Cs. Naturales
  scoreGHC String?  // Geo. Hist. y Ciudadanía
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([studentId, anioEscolar, grado, seccion])
  @@index([anioEscolar, grado, seccion])
}
